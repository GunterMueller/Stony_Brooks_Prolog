/*  This file defines some arithmetic library predicates */

$arith_export([$floatc/3,$exp/2,$square/2,$sin/2,$floor/2]).

$floatc(FNum,Mant,Exp) :-
	$number(FNum), var(Mant), var(Exp), !,
	$b_floatc(FNum,Mant,Exp,0).
$floatc(FNum,Mant,Exp) :-
	$number(Mant),
	(integer(Exp) ->
		(var(FNum) ->
		     $b_floatc(FNum,Mant,Exp,1) ;
		     ($number(FNum) ->
		          $b_floatc(FNum,Mant,Exp,2) ;
		          ($errmsg('*** Error: invalid arguments to floatc ***'), fail)
		     )
		)
	).

$exp(X, Y) :- var(X) ->
	(($number(Y), Y > 0) -> $b_arith(X, Y, 0) ;
	     ($errmsg('*** illegal second argument to exp/2 ***'), fail)
	) ;
	($number(X) ->
	     $b_arith(X,Y,1) ;
	     ($errmsg('*** illegal first argument to exp/2 ***'), fail)
	).

$square(X, Y) :- var(X) ->
	($number(Y) -> $b_arith(X, Y, 2) ;
	     ($errmsg('*** illegal second argument to square/2 ***'), fail)
	) ;
	($number(X) ->
	     $b_arith(X,Y,3) ;
	     ($errmsg('*** illegal first argument to square/2 ***'), fail)
	).

$sin(X, Y) :- var(X) ->
	($number(Y) -> $b_arith(X, Y, 5) ;
	       ($errmsg('*** illegal second argument to sin/2 ***'), fail)
	) ;
	($number(X) ->
		$b_arith(X,Y,4) ;
	       ($errmsg('*** illegal first argument to sin/2 ***'), fail)
	).

$b_arith(X, Y, N) :- '_$builtin'(60).
$b_floatc(F,M,E,S) :- '_$builtin'(61).

$floor(F,I) :-
	real(F) ->
		(var(I) ->
			$floor0(F,I,0) ;
			(integer(I) ->
				F = I ;
				($errmsg('*** second argument to floor/2 must be variable or integer ***'),
				 fail)
			)
		) ;
		(var(F) ->
			(integer(I) ->
				$floor0(F,I,1) ;
				($errmsg('*** first argument to floor/2 must be variable or real ***'),
				 fail)
			) ;
			($errmsg('*** first argument to floor/2 must be variable or real ***'),
			 fail
			)
		).

$floor0(F,I,N) :- '_$builtin'(63).



